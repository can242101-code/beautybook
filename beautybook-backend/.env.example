APP_NAME=BeautyBook
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# --- PRODUCCION (Railway) ---
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://tu-backend.railway.app
# FRONTEND_URL=https://tu-frontend.vercel.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Base de datos — PostgreSQL
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=beautybook_db
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

# Caché — Redis (usar predis en Windows con Memurai)
CACHE_STORE=redis
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- PRODUCCION Redis (Upstash) ---
# REDIS_HOST=tu-host.upstash.io
# REDIS_PASSWORD=tu-password-upstash
# REDIS_PORT=6379

# Correo — Brevo (smtp-relay.brevo.com : 587)
# Obtén la clave SMTP en: app.brevo.com → Transaccional → Configuración → SMTP y API
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=tu_email@ejemplo.com
MAIL_PASSWORD=clave_smtp_brevo
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@beautybook.com"
MAIL_FROM_NAME="BeautyBook"

# URL del frontend — se usa en el enlace de recuperación de contraseña
FRONTEND_URL=http://localhost:3000

VITE_APP_NAME="${APP_NAME}"
